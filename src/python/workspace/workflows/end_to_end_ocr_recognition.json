  "metadata": {
    "name": "端到端示例：OCR 文字识别完整流程",
    "description": "展示 OCR 插件的三种核心功能：通用文字识别、表格识别、版面分析",
    "version": "1.0.0",
    "author": "OpenCV Team",
    "created_at": "2026-04-26",
    "tags": ["example", "ocr", "paddleocr", "text-recognition", "end-to-end"],
    "workflow_steps": [
      {
        "step": 1,
        "name": "通用文字识别",
        "node": "node_ocr_recognize",
        "description": "识别文档中的文字内容，支持中英文混合"
      },
      {
        "step": 2,
        "name": "表格识别",
        "node": "node_ocr_table",
        "description": "识别表格结构并导出为 Excel/CSV/JSON 格式"
      },
      {
        "step": 3,
        "name": "版面分析",
        "node": "node_ocr_layout",
        "description": "分析文档版面结构，识别标题、段落、图片等区域"
      }
    ],
    "hardware_requirements": {
      "cpu_cores": 4,
      "memory_gb": 8,
      "gpu_required": false,
      "gpu_memory_gb": 0,
      "recommended_gpu": "可选，有 GPU 可加速推理"
    },
    "performance_expectations": {
      "text_recognition": "~200ms/页（CPU）",
      "table_recognition": "~500ms/页（CPU）",
      "layout_analysis": "~400ms/页（CPU）",
      "with_gpu": "速度提升 2-3x"
    },
    "usage_tips": [
      "修改各 ImageLoadNode 的 file_path 为你的实际图像路径",
      "通用文字识别适合快速提取文本内容",
      "表格识别需要清晰的表格图像，避免倾斜或变形",
      "版面分析适合复杂文档，可识别标题、段落、图片等结构",
      "首次运行会下载模型文件（约 100MB），请耐心等待",
      "建议先使用通用 OCR 验证图像质量，再进行表格或版面分析"
    ]
  }
}
