  "metadata": {
    "name": "端到端示例：图像采集 → 预处理 → AI 推理",
    "description": "完整的工作流示例，展示从图像加载、预处理（灰度化+高斯模糊）到 YOLO 目标检测的完整流程",
    "version": "1.0.0",
    "author": "OpenCV Team",
    "created_at": "2026-04-26",
    "tags": ["example", "yolo", "preprocessing", "end-to-end"],
    "workflow_steps": [
      {
        "step": 1,
        "name": "图像采集",
        "node": "node_image_load",
        "description": "从文件加载图像，支持 JPG/PNG/BMP 等格式"
      },
      {
        "step": 2,
        "name": "灰度化预处理",
        "node": "node_grayscale",
        "description": "将彩色图像转换为灰度图像，减少计算量"
      },
      {
        "step": 3,
        "name": "高斯模糊降噪",
        "node": "node_gaussian_blur",
        "description": "应用高斯滤波器去除噪声，提升检测精度"
      },
      {
        "step": 4,
        "name": "YOLO 目标检测",
        "node": "node_yolo_detect",
        "description": "使用 YOLOv8n 模型进行实时目标检测，识别常见物体"
      },
      {
        "step": 5,
        "name": "结果可视化",
        "node": "node_image_display",
        "description": "显示带有检测框和标签的最终结果图像"
      }
    ],
    "hardware_requirements": {
      "cpu_cores": 2,
      "memory_gb": 4,
      "gpu_required": false,
      "gpu_memory_gb": 0,
      "recommended_gpu": "可选，有 GPU 可加速 YOLO 推理"
    },
    "performance_expectations": {
      "without_gpu": "~100ms/帧 (yolov8n)",
      "with_gpu": "~20ms/帧 (yolov8n)",
      "total_latency": "约 150-200ms（包含预处理）"
    },
    "usage_tips": [
      "修改 node_image_load 的 file_path 为你自己的图像路径",
      "可以根据需要调整高斯模糊的 kernel_size（3-15，奇数）",
      "YOLO 模型可选择 yolov8n/yolov8s/yolov8m 等不同大小的模型",
      "置信度阈值 confidence_threshold 建议设置为 0.3-0.7",
      "双击 ImageViewNode 节点可查看实时预览"
    ]
  }
}
