  "installation_guide": {
    "inference_only": {
      "description": "仅推理模式（工厂现场部署）",
      "install_mode": "pip_install",
      "commands": [
        "pip install paddlepaddle>=2.4.0",
        "pip install paddleocr>=2.6.0"
      ],
      "estimated_size_mb": 500,
      "download_time_minutes": 10
    },
    "full_suite": {
      "description": "完整套件（含 GPU 支持和训练工具）",
      "install_mode": "pip_install",
      "commands": [
        "pip install paddlepaddle-gpu>=2.4.0",
        "pip install paddleocr>=2.6.0",
        "pip install openpyxl pandas"
      ],
      "estimated_size_mb": 2000,
      "download_time_minutes": 30
    }
