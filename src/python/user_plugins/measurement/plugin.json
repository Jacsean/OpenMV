    {
      "class": "BoundingBoxNode",
      "display_name": "边界框检测",
      "category": "尺寸测量",
      "color": [255, 150, 100]
    }
  ],
  "dependencies": ["opencv-python>=4.5", "numpy"],
  "min_app_version": "4.0.0"
}
