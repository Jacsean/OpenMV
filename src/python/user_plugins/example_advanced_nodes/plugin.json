      "color": [200, 150, 255]
    },
    {
      "class": "AdaptiveThresholdNode",
      "display_name": "自适应阈值",
      "category": "二值化",
      "color": [255, 200, 150]
    },
    {
      "class": "HistogramEqualizeNode",
      "display_name": "直方图均衡化",
      "category": "增强",
      "color": [150, 255, 200]
    }
  ],
  "dependencies": ["opencv-python>=4.5", "numpy"],
  "min_app_version": "4.0.0"
}
